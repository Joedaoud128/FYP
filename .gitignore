agent-sandbox-pkgs-*/
.docker/

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────
.DS_Store
.Spotlight-V100
.Trashes
ehthumbs.db

# ── Temporary files ───────────────────────────────────────
/tmp/
*.tmp
*.bak

# ── Secrets (never commit) ────────────────────────────────
.env
*.key
*.pem