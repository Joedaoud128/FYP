# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Generated Output (created at runtime) ─────────────────
generated_code/
*.pyc

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────
